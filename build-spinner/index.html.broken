<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Daily Build Spinner (mock)</title>
  <style>
    :root{--bg:#fffaf2;--ink:#151515;--muted:#5a5a5a;--a:#111827;--b:#ff9a1f;--line:rgba(0,0,0,.14)}
    *{box-sizing:border-box}
    body{margin:0;font-family:ui-sans-serif,system-ui,Segoe UI,Roboto,Arial;color:var(--ink);background:
      radial-gradient(900px 600px at 18% 0%, rgba(255,154,31,.20), transparent 58%),
      radial-gradient(900px 640px at 90% 20%, rgba(17,24,39,.10), transparent 60%),
      linear-gradient(180deg, #fffaf2, #fff);
      background-attachment: fixed, fixed, fixed;
      min-height:100vh; padding:20px;
    }
    header{display:flex;justify-content:space-between;align-items:center;gap:12px;max-width:1100px;margin:0 auto 14px}
    h1{margin:0;font-size:18px;letter-spacing:.2px}
    .muted{color:var(--muted);font-size:12px}
    .btn{cursor:pointer;border-radius:14px;padding:10px 12px;border:2px solid var(--a);background:#fff;color:var(--a);font-weight:font-weight:800; min-height; min-height; min-height:44px; display:inline-flex; align-items:center;}
    .btn.primary{background:var(--a);color:#fff}

    .wrap{max-width:1100px;margin:0 auto;display:grid;grid-template-columns: 1fr 380px;gap:14px}
    .card{background:#fff;border:2px solid var(--a);border-radius:18px;box-shadow: 8px 10px 0 rgba(0,0,0,.10);overflow:hidden}
    .head{padding:12px 14px;border-bottom:2px solid var(--a);display:flex;justify-content:space-between;align-items:center}
    .head b{letter-spacing:1px;text-transform:uppercase}
    .body{padding:14px}

    .spinner{display:grid;place-items:center;padding:10px}
    .wheel{width:320px;height:320px;border-radius:999px;border:3px solid var(--a);background:conic-gradient(#ff9a1f 0 60deg, #fef3c7 60deg 120deg, #111827 120deg 180deg, #fde68a 180deg 240deg, #334155 240deg 300deg, #fff 300deg 360deg);
      position:relative;
    }
    .wheel::after{content:""; position:absolute; inset:26px; border-radius:999px; background:#fff; border:2px solid var(--a)}
    .pin{width:0;height:0;border-left:10px solid transparent;border-right:10px solid transparent;border-bottom:18px solid var(--a); margin:0 auto 10px}
    .prompt{margin-top:12px;padding:12px;border:2px dashed rgba(17,24,39,.35);border-radius:16px;background:rgba(255,154,31,.10)}
    .prompt h2{margin:0 0 6px;font-size:14px}
    .prompt .big{font-weight:900;font-size:18px}

    .grid{display:grid;gap:10px}
    label{font-size:12px;color:var(--muted)}
    select{width:100%;padding:10px 12px;border-radius:14px;border:2px solid var(--a);background:#fff;font-weight:700}
    .hist{display:grid;gap:8px;margin-top:10px}
    .h{padding:10px;border:1px solid rgba(0,0,0,.12);border-radius:14px;background:rgba(0,0,0,.03)}

    @media(max-width:980px){.wrap{grid-template-columns:1fr}}
  </style>
</head>
<body>
<header>
  <div>
    <h1>Daily Build Spinner</h1>
    <div class="muted">A weirdly effective way to force shipping something.</div>
  </div>
  <div style="display:flex;gap:10px;flex-wrap:wrap">
    <button class="btn" onclick="location.href='/mockups/'">Mockups</button>
    <button class="btn primary" id="spin">Spin</button>
  </div>
</header>

<main class="wrap">
  <section class="card">
    <div class="head"><b>Spin</b><span class="muted">neo‑brutal</span></div>
    <div class="body">
      <div class="spinner">
        <div class="pin"></div>
        <div class="wheel" id="wheel" aria-hidden="true"></div>
        <div class="prompt" id="prompt">
          <h2>Prompt</h2>
          <div class="big">—</div>
          <div class="muted" id="spec">—</div>
        </div>
      </div>
    </div>
  </section>

  <aside class="card">
    <div class="head"><b>Constraints</b><span class="muted">saved</span></div>
    <div class="body">
      <div class="grid">
        <div>
          <label>Timebox</label>
          <select id="timebox"><option>15 min</option><option selected>30 min</option><option>60 min</option></select>
        </div>
        <div>
          <label>Vibe</label>
          <select id="vibe"><option selected>Elegant</option><option>Playful</option><option>Serious</option><option>Weird</option></select>
        </div>
        <div>
          <label>Constraint</label>
          <select id="cons"><option selected>One page</option><option>Offline only</option><option>Keyboard first</option><option>Mobile first</option></select>
        </div>
      </div>

      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:12px">
        <button class="btn" id="copyLast" title="Copy current prompt + constraints">Copy last</button>
        <button class="btn" id="exportMd" title="Copy history as Markdown">Export .md</button>
        <button class="btn" id="editPrompts" title="Customize prompt list">Edit prompts</button>
      </div>

      <div class="muted" style="margin-top:12px">History</div>
      <div class="hist" id="hist"></div>
    </div>
  </aside>
</main>

<dialog id="dlg" style="border:2px solid var(--a); border-radius:16px; padding:14px; max-width:720px; width:calc(100% - 24px)">
  <div style="display:flex;justify-content:space-between;align-items:center;gap:12px">
    <b style="letter-spacing:1px;text-transform:uppercase">Edit prompts</b>
    <button class="btn" id="closeDlg">Close</button>
  </div>
  <div class="muted" style="margin:8px 0 10px">One prompt per line. Saved locally in your browser.</div>
  <textarea id="promptBox" style="width:100%;min-height:220px;border-radius:14px;border:2px solid var(--a);padding:10px 12px;font:inherit"></textarea>
  <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:10px">
    <button class="btn primary" id="savePrompts">Save</button>
    <button class="btn" id="resetPrompts">Reset defaults</button>
  </div>
</dialog>

<script>
  const KEY='spinner-v1';
  const KEY_PROMPTS='spinner-prompts-v1';
  const wheel=document.getElementById('wheel');
  const prompt=document.getElementById('prompt');
  const spec=document.getElementById('spec');
  const hist=document.getElementById('hist');

  const DEFAULT_PROMPTS=[
    'Build an instant expense splitter',
    'Make a packing checklist with progress bar',
    'Design a calm focus timer with sound toggle',
    'Create a “what’s on soon” olympics widget',
    'Make a grocery list with aisle grouping',
    'Build a tiny habit tracker (forgiving streak)'
  ];

  function loadPrompts(){
    try{
      const raw = localStorage.getItem(KEY_PROMPTS);
      if(!raw) return DEFAULT_PROMPTS.slice();
      const lines = raw.split(/\r?\n/).map(s=>s.trim()).filter(Boolean);
      return lines.length ? lines : DEFAULT_PROMPTS.slice();
    }catch{return DEFAULT_PROMPTS.slice()}
  }

  let P = loadPrompts();
  let lastSpin = null;

  function load(){ try{return JSON.parse(localStorage.getItem(KEY)||'[]')}catch{return []} }
  function save(x){ localStorage.setItem(KEY, JSON.stringify(x)); }

  function renderHist(){
    const items=load().slice(0,6);
    hist.innerHTML = items.map(i=>`<div class="h"><b>${i.title}</b><div class="muted">${i.spec}</div></div>`).join('') || '<div class="muted">No spins yet.</div>';
  }

  function spin(){
    const tb=document.getElementById('timebox').value;
    const vibe=document.getElementById('vibe').value;
    const cons=document.getElementById('cons').value;

    // avoid immediate repeats if possible
    let title = P[Math.floor(Math.random()*P.length)];
    if(lastSpin && P.length > 1){
      for(let tries=0; tries<5 && title===lastSpin.title; tries++){
        title = P[Math.floor(Math.random()*P.length)];
      }
    }

    const s = `${tb} • ${vibe} • ${cons}`;

    wheel.animate([
      {transform:'rotate(0deg)'},
      {transform:`rotate(${720 + Math.floor(Math.random()*720)}deg)`}
    ], {duration:900, easing:'cubic-bezier(.2,.8,.2,1)'});

    prompt.querySelector('.big').textContent = title;
    spec.textContent = s;

    lastSpin = { title, spec:s, at:Date.now() };

    const items=load();
    items.unshift(lastSpin);
    save(items);
    renderHist();
  }

  async function copyText(t){
    try{
      await navigator.clipboard.writeText(t);
      return true;
    }catch{
      const ta=document.createElement('textarea');
      ta.value=t; document.body.appendChild(ta);
      ta.select();
      try{ document.execCommand('copy'); }catch{}
      ta.remove();
      return false;
    }
  }

  document.getElementById('copyLast').onclick=async()=>{
    if(!lastSpin) return;
    await copyText(`${lastSpin.title}\n${lastSpin.spec}`);
  };

  document.getElementById('exportMd').onclick=async()=>{
    const items=load().slice(0,12);
    const md = [
      '# Build Spinner — history',
      '',
      ...items.map(i=>`- **${i.title}** — ${i.spec}`)
    ].join('\n');
    await copyText(md);
  };

  const dlg=document.getElementById('dlg');
  const promptBox=document.getElementById('promptBox');

  function openDlg(){
    P = loadPrompts();
    promptBox.value = P.join('\n');
    if(dlg.showModal) dlg.showModal(); else dlg.setAttribute('open','');
  }
  function closeDlg(){
    if(dlg.close) dlg.close(); else dlg.removeAttribute('open');
  }

  document.getElementById('editPrompts').onclick=openDlg;
  document.getElementById('closeDlg').onclick=closeDlg;

  document.getElementById('savePrompts').onclick=()=>{
    localStorage.setItem(KEY_PROMPTS, promptBox.value);
    P = loadPrompts();
    closeDlg();
  };

  document.getElementById('resetPrompts').onclick=()=>{
    localStorage.removeItem(KEY_PROMPTS);
    P = loadPrompts();
    promptBox.value = P.join('\n');
  };

  document.getElementById('spin').onclick=spin;

  // keyboard: Space to spin, Ctrl/Cmd+E export, Ctrl/Cmd+P edit prompts
  window.addEventListener('keydown', (e)=>{
    if((e.ctrlKey||e.metaKey) && e.key.toLowerCase()==='e'){
      e.preventDefault();
      document.getElementById('exportMd').click();
      return;
    }
    if((e.ctrlKey||e.metaKey) && e.key.toLowerCase()==='p'){
      e.preventDefault();
      openDlg();
      return;
    }
    if(e.key === ' ' && !(e.target && ['INPUT','TEXTAREA','SELECT'].includes(e.target.tagName))){
      e.preventDefault();
      spin();
    }
  });

  ['timebox','vibe','cons'].forEach(id=>document.getElementById(id).oninput=()=>renderHist());

  renderHist();
  spin();
</script>
<script src="/mockups/tracking.js"></script>
</body>
</html>
